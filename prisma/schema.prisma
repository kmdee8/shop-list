generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id        Int      @id @default(autoincrement())
  name      String
  done      Boolean  @default(false)
  position  Int      @default(0)
  createdAt DateTime @default(now())
}

model GroceryInventory {
  id       Int    @id @default(autoincrement())
  name     String @unique
  category String @default("General")
}

